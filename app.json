{
  "expo": {
    "name": "쿠몽",
    "slug": "coumong",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "coumongappv2",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.andrewdo71.coumong",
      "supportsTablet": true,
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "검색 결과 제공을 위해 사용자의 위치 정보가 필요합니다.",
        "NSCameraUsageDescription": "사진 업로드를 위해 카메라 권한이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "사진 선택을 위해 갤러리 접근 권한이 필요합니다."
      }
    },
    "android": {
      "package": "com.andrewdo71.coumong",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E8456B",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4e81a208-f774-488a-9682-382271c5e5c0"
      }
    },
    "owner": "andrewdo1971"
  }
}
